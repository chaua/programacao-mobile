<?xml version="1.0" encoding="utf-8"?>
<layout
    xmlns:android="http://schemas.android.com/apk/res/android">

    <data />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Aula08 Ciclo de Vida -->
            <TextView
                android:id="@+id/main_txt_ciclo_de_vida"
                style="@style/titulo"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/main_txt_ciclo_de_vida" />

            <TextView
                android:id="@+id/main_desc_ciclo_de_vida"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/main_desc_ciclo_de_vida" />

            <Button
                android:id="@+id/main_btn_ciclo_de_vida"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_normal"
                android:layout_marginBottom="@dimen/spacing_larger"
                android:text="@string/main_btn_ciclo_de_vida" />

            <!-- Aula09 LinearLayout -->
            <TextView
                android:id="@+id/main_txt_linear_layout"
                style="@style/titulo"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/main_txt_linear_layout" />

            <TextView
                android:id="@+id/main_desc_linear_layout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/main_desc_linear_layout" />

            <Button
                android:id="@+id/main_btn_linear_layout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_normal"
                android:layout_marginBottom="@dimen/spacing_larger"
                android:text="@string/main_btn_linear_layout" />

            <!-- Aula10 ConstraintLayout -->
            <TextView
                android:id="@+id/main_txt_constraint_layout"
                style="@style/titulo"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/main_txt_constraint_layout" />

            <TextView
                android:id="@+id/main_desc_constraint_layout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/main_desc_constraint_layout" />

            <Button
                android:id="@+id/main_btn_constraint_layout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_normal"
                android:layout_marginBottom="@dimen/spacing_larger"
                android:text="@string/main_btn_constraint_layout" />

            <!-- Aula12 Acesso com Data Binding -->
            <TextView
                android:id="@+id/main_txt_acesso_com_data_binding"
                style="@style/titulo"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/main_txt_acesso_com_data_binding" />

            <TextView
                android:id="@+id/main_desc_acesso_com_data_binding"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/main_desc_acesso_com_data_binding" />

            <Button
                android:id="@+id/main_btn_acesso_com_data_binding"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_normal"
                android:layout_marginBottom="@dimen/spacing_larger"
                android:text="@string/main_btn_acesso_com_data_binding" />

            <!-- Aula12 Acesso sem Data Binding -->
            <TextView
                android:id="@+id/main_txt_acesso_sem_data_binding"
                style="@style/titulo"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/main_txt_acesso_sem_data_binding" />

            <TextView
                android:id="@+id/main_desc_acesso_sem_data_binding"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/main_desc_acesso_sem_data_binding" />

            <Button
                android:id="@+id/main_btn_acesso_sem_data_binding"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_normal"
                android:layout_marginBottom="@dimen/spacing_larger"
                android:text="@string/main_btn_acesso_sem_data_binding" />

            <!-- Aula13 Componentes de Texto -->
            <TextView
                android:id="@+id/main_txt_componentes_texto"
                style="@style/titulo"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/main_txt_componentes_texto" />

            <TextView
                android:id="@+id/main_desc_componentes_texto"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/main_desc_componentes_texto" />

            <Button
                android:id="@+id/main_btn_componentes_texto"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_normal"
                android:layout_marginBottom="@dimen/spacing_larger"
                android:text="@string/main_btn_componentes_texto" />

            <!-- Aula14 Componentes de Botão -->
            <TextView
                android:id="@+id/main_txt_componentes_botao"
                style="@style/titulo"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/main_txt_componentes_botao" />

            <TextView
                android:id="@+id/main_desc_componentes_botao"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/main_desc_componentes_botao" />

            <Button
                android:id="@+id/main_btn_componentes_botao"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_normal"
                android:layout_marginBottom="@dimen/spacing_larger"
                android:text="@string/main_btn_componentes_botao" />

            <!-- Aula15 Fragmentos Bottom Navigation -->
            <TextView
                android:id="@+id/main_txt_fragmentos_bottom_nav"
                style="@style/titulo"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/main_txt_fragmentos_bottom_nav" />

            <TextView
                android:id="@+id/main_desc_fragmentos_bottom_nav"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/main_desc_fragmentos_bottom_nav" />

            <Button
                android:id="@+id/main_btn_fragmentos_bottom_nav"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_normal"
                android:layout_marginBottom="@dimen/spacing_larger"
                android:text="@string/main_btn_fragmentos_bottom_nav" />

            <!-- Aula15 Fragmentos Tab Layout -->
            <TextView
                android:id="@+id/main_txt_fragmentos_tab_layout"
                style="@style/titulo"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/main_txt_fragmentos_tab_layout" />

            <TextView
                android:id="@+id/main_desc_fragmentos_tab_layout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/main_desc_fragmentos_tab_layout" />

            <Button
                android:id="@+id/main_btn_fragmentos_tab_layout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_normal"
                android:layout_marginBottom="@dimen/spacing_larger"
                android:text="@string/main_btn_fragmentos_tab_layout" />

            <!-- Aula15 Fragmentos ViewPager -->
            <TextView
                android:id="@+id/main_txt_fragmentos_view_pager"
                style="@style/titulo"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/main_txt_fragmentos_view_pager" />

            <TextView
                android:id="@+id/main_desc_fragmentos_view_pager"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/main_desc_fragmentos_view_pager" />

            <Button
                android:id="@+id/main_btn_fragmentos_view_pager"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_normal"
                android:layout_marginBottom="@dimen/spacing_larger"
                android:text="@string/main_btn_fragmentos_view_pager" />

            <!-- Aula16 RecyclerView -->
            <TextView
                android:id="@+id/main_txt_recycler_view"
                style="@style/titulo"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/main_txt_recycler_view" />

            <TextView
                android:id="@+id/main_desc_recycler_view"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/main_desc_recycler_view" />

            <Button
                android:id="@+id/main_btn_recycler_view"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_normal"
                android:layout_marginBottom="@dimen/spacing_larger"
                android:text="@string/main_btn_recycler_view" />

        </LinearLayout>
    </ScrollView>
</layout>
